# ── LLM (Gemini) ───────────────────────────────────────────────────────────
# Used ONLY for answer generation in llm_service.py
# Get your key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GENERATION_MODEL=gemini-3-flash-preview

# ── Embedding model ────────────────────────────────────────────────────────
# Used ONLY in embedding_service.py — for BOTH repo ingestion and query search
# Local model, runs on your machine — no API key, no cost, no internet after first download
# DO NOT change this without also updating VECTOR_SIZE in vector_service.py and re-ingesting
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Vector DB (Qdrant) ─────────────────────────────────────────────────────
# Run locally: docker run -p 6333:6333 qdrant/qdrant
QDRANT_URL=http://localhost:6333
COLLECTION_NAME=codebase